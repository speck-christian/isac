#!/usr/bin/env bash
set -euo pipefail

if [[ "${SKIP_REPORT_CHECK:-0}" == "1" ]]; then
  exit 0
fi

staged_files="$(git diff --cached --name-only)"

if [[ -z "$staged_files" ]]; then
  exit 0
fi

needs_report_update=0
while IFS= read -r path; do
  [[ -z "$path" ]] && continue
  case "$path" in
    docs/report/technical_report.tex|docs/report/build/technical_report.pdf)
      ;;
    *)
      needs_report_update=1
      ;;
  esac
done <<< "$staged_files"

if [[ "$needs_report_update" -eq 1 ]]; then
  if ! grep -qx 'docs/report/technical_report.tex' <<< "$staged_files"; then
    echo "pre-commit: code or docs changed without updating docs/report/technical_report.tex"
    echo "If this commit truly does not affect the report, bypass with SKIP_REPORT_CHECK=1 git commit ..."
    exit 1
  fi
fi
